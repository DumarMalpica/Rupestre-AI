# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Opciones: mock | ollama | openai | anthropic
# "mock" no requiere ninguna API key y es útil para desarrollo/tests
LLM_PROVIDER=mock

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Requerida solo si LLM_PROVIDER=openai
OPENAI_API_KEY=

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Requerida si LLM_PROVIDER=anthropic. Visión (descripción) + interpretación RAG.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
VISION_MODEL=claude-sonnet-4-6

# ─── Ollama (local) ───────────────────────────────────────────────────────────
# URL base del servidor Ollama (por defecto puerto 11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo a usar en Ollama
OLLAMA_MODEL=llama3.3

# ─── MongoDB (vector store) ───────────────────────────────────────────────────
# Railway inyecta estas variables automáticamente. En local, exporta
# MONGO_PUBLIC_URL (proxy TCP) para indexar el corpus desde tu máquina.
# NO pongas credenciales reales aquí — solo en las variables de entorno.
MONGO_URL=
MONGO_PUBLIC_URL=
MONGO_DB=rupestre
MONGO_COLLECTION=corpus_rupestre
# Número de pasajes del corpus recuperados por consulta
CORPUS_TOP_K=4

# ─── Detección + clasificación de motivos ─────────────────────────────────────
# Umbral de confianza de YOLO. Bajo = detecta más figuras (más recall); las
# figuras genéricas las reclasifica Claude visión recortando cada caja.
# La clasificación por visión requiere LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY.
MOTIF_CONFIDENCE_THRESHOLD=0.2
# Máximo de recortes enviados a Claude por imagen (control de costo)
MOTIF_MAX_CLASSIFY=20

# ─── Directorios de salida ────────────────────────────────────────────────────
# Donde se guardan las fichas generadas (PDF + JSON)
OUTPUT_DIR=./data/fichas
# Directorio con imágenes de muestra para pruebas
SAMPLES_DIR=./data/samples

# ─── Control de calidad de imagen ────────────────────────────────────────────
# Resolución mínima aceptable en píxeles totales (1_000_000 = 1 MP)
MIN_IMAGE_RESOLUTION=1000000
# Umbral de varianza de Laplaciano por debajo del cual la imagen se considera borrosa
BLUR_THRESHOLD=100.0

# ─── Human-in-the-Loop ───────────────────────────────────────────────────────
# Confianza mínima de interpretación cultural; por debajo se solicita revisión humana
HITL_CONFIDENCE_THRESHOLD=0.6

# ─── LaMa Inpainting ───────────────────────────────────────────────────────────
# Activar/desactivar LaMa (paso extra tras la reconstrucción)
LAMA_ENABLED=True
# Dispositivo: "cpu" o "cuda" (si tienes GPU NVIDIA)
LAMA_DEVICE=cpu

# ─── Langfuse (observabilidad / trazas) ──────────────────────────────────────
# Si se dejan vacíos, el sistema usa un tracer mock que no registra nada
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# SDK v4 usa LANGFUSE_HOST. LANGFUSE_BASE_URL también funciona (se mapea automáticamente).
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Twilio WhatsApp Bot ──────────────────────────────────────────────────────
# Obtener en: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Número del Sandbox de Twilio (no cambia en dev) o tu número aprobado en prod
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Dominio público del deploy (Railway lo asigna automáticamente)
RAILWAY_PUBLIC_DOMAIN=rupestre-ai-production.up.railway.app
