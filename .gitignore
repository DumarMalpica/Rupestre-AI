# ── Secretos y configuración local ───────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Entornos virtuales ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenv/

# ── Imágenes (originales, realzadas, anotadas, máscaras) ─────────────────────
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.tif
*.webp
*.svg
*.heic
*.raw

# ── PDFs generados ────────────────────────────────────────────────────────────
*.pdf

# ── Directorios de datos generados en runtime ─────────────────────────────────
data/samples/
data/fichas/
data/chroma/
data/icanh_docs/

# Mantener la estructura de directorios vacíos
!data/.gitkeep
!data/samples/.gitkeep
!data/fichas/.gitkeep

# ── Pesos de modelos ML (archivos grandes) ────────────────────────────────────
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.pkl
*.h5
*.weights
models/yolov11/weights/
models/deepfillv2/weights/

# ── ChromaDB ──────────────────────────────────────────────────────────────────
